autoload -Uz vcs_info
setopt prompt_subst

zstyle ':vcs_info:git:*' formats ' (%b)'

precmd() {
  local last_status=$?
  vcs_info

  # ── color scheme ──
  local line_color="%F{13}"    # purple  – fill line, username
  local warn_color="%F{196}"   # red     – exit code, detached HEAD
  local path_color="%F{11}"    # yellow  – working directory
  local git_color="%F{8}"      # gray    – git branch
  local venv_color="%F{12}"    # blue    – virtual-env marker
  local reset="%f"

  local exit_part=""
  local ctx=""
  local user_part=""
  local path_display=""
  local full_path="${PWD/#$HOME/~}"
  local git_part="$vcs_info_msg_0_"


  if [[ -n $git_part ]]; then
    local git_branch
    git_branch=$(git symbolic-ref --quiet --short HEAD 2>/dev/null)
    if [[ -z $git_branch ]]; then
      local git_rev
      git_rev=$(git rev-parse --short HEAD 2>/dev/null)
      git_part=" ${warn_color}(DETACHED${git_rev:+ @ ${git_rev}})${reset}"
    fi
  fi

  # exit code on left, only when non-zero
  if (( last_status != 0 )); then
    exit_part="${warn_color}[${last_status}]${reset} "
  fi

  # SSH marker
  if [[ -n $SSH_CONNECTION ]]; then
    ctx="${warn_color}[SSH]%f "
  fi

  # username color
  if [[ $EUID -eq 0 ]]; then
    user_part="${warn_color}%n${line_color}"
  elif [[ $USER == tyler ]]; then
    user_part="${line_color}%n"
  else
    user_part="%n"
  fi
  user_part="${user_part}${line_color}@%m"


  # path rule:
  # full ~/relative path if under 40 chars, else basename only
  if (( ${#full_path} < 40 )); then
    path_display="$full_path"
  else
    path_display="${PWD:t}"
  fi

  local right="${ctx}${user_part}"
  local fill_len=$(( COLUMNS - ${#${(%)exit_part}} - ${#${(%)right}} ))
  (( fill_len < 1 )) && fill_len=1
  local fill=${(pl.$fill_len..-.)}

  local venv_part=""
  if [[ -n $VIRTUAL_ENV ]]; then
    venv_part="${venv_color}(${VIRTUAL_ENV:t})${reset} "
  fi

  PROMPT="${exit_part}${line_color}${fill}${reset}${right}
${venv_part}${path_color}${path_display}${reset}${git_color}${git_part}${reset} %# "
}
